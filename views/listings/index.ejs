<% layout("/layouts/boilerplate") %>

  <!-- Include a client-side script variable so we know the current category to highlight it -->
  <script>
    window.currentCategory = "<%= typeof currentCategory !== 'undefined' ? currentCategory : '' %>";
  </script>

  <div id="filter" class="d-flex align-items-center mb-4">
    <a href="/listings?category=Trending" class="filter text-decoration-none">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </a>
    <a href="/listings?category=Rooms" class="filter text-decoration-none">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </a>
    <a href="/listings?category=Iconic Cities" class="filter text-decoration-none">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Cities</p>
    </a>
    <a href="/listings?category=Mountains" class="filter text-decoration-none">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </a>
    <a href="/listings?category=Castles" class="filter text-decoration-none">
      <div><i class="fa-solid fa-chess-rook"></i></div>
      <p>Castles</p>
    </a>
    <a href="/listings?category=Pools" class="filter text-decoration-none">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Pools</p>
    </a>
    <a href="/listings?category=Camping" class="filter text-decoration-none">
      <div><i class="fa-solid fa-caravan"></i></div>
      <p>Camping</p>
    </a>
    <a href="/listings?category=Farms" class="filter text-decoration-none">
      <div><i class="fa-solid fa-tractor"></i></div>
      <p>Farms</p>
    </a>



    <!-- Clear Filters -->
    <a href="/listings" class="filter text-decoration-none text-danger" style="margin-right: 2rem;">
      <div><i class="fa-solid fa-xmark"></i></div>
      <p>Clear</p>
    </a>

    <div class="tax-toggle ms-auto me-2">
      <div class="form-check form-switch form-check-reverse m-0">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label ms-2 mt-1 fw-semibold text-muted" for="switchCheckDefault"
          style="font-size: 14px; cursor: pointer;">Display total after taxes</label>
      </div>
    </div>
  </div>

  <% if (typeof searchQuery !=='undefined' && searchQuery) { %>
    <h4 class="mb-4 text-dark">Results for "<%= searchQuery %>"</h4>
    <% } %>

      <% if (allListings && allListings.length> 0) { %>
        <div class="row row-cols-xl-4 row-cols-lg-3 row-cols-sm-2 row-cols-1 g-3 g-md-4">
          <% for(let listing of allListings) { %>
            <div class="col">
              <div class="card card-listing h-100 position-relative">
                <!-- Stretched overlay link for the entire card -->
                <a href="/listings/<%= listing._id %>" class="position-absolute top-0 start-0 w-100 h-100" style="z-index: 1;" title="<%= listing.title %>"></a>
                
                <div class="image-wrapper shadow-sm">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>">
                    <!-- Heart container (needs z-index > 1 to sit above the card link overlay) -->
                    <div class="position-absolute top-0 end-0 p-3" style="z-index: 2;">
                      <% if (currUser) {
                           const isFav = currUser.favourites && currUser.favourites.some(f => f && f.toString() === listing._id.toString());
                      %>
                        <form action="/favourite/<%= listing._id %><%= isFav ? '?_method=DELETE' : '' %>" method="POST"
                          class="d-inline heart-form" onclick="event.stopPropagation();">
                          <button type="submit" class="btn p-0 border-0 bg-transparent heart-btn"
                            title="<%= isFav ? 'Remove from Favourites' : 'Save to Favourites' %>"
                            style="line-height:1;">
                            <i class="<%= isFav ? 'fa-solid' : 'fa-regular' %> fa-heart fs-4 <%= isFav ? 'text-danger' : 'text-white' %>"
                              style="filter: drop-shadow(0 2px 4px rgba(0,0,0,0.6));"></i>
                          </button>
                        </form>
                      <% } else { %>
                        <a href="/login" onclick="event.stopPropagation();" title="Log in to save">
                          <i class="fa-regular fa-heart fs-4 text-white"
                            style="filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));"></i>
                        </a>
                      <% } %>
                    </div>
                  </div>
                  <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                      <p class="listing-location mb-0 me-2"><%= listing.location %>, <%= listing.country %></p>
                      <span class="listing-rating">
                        <i class="fa-solid fa-star"></i> 4.9
                      </span>
                    </div>
                    <p class="listing-sub mb-0"><%= listing.title %></p>
                    <p class="listing-price mb-0">
                      &#8377; <%= listing.price ? listing.price.toLocaleString('en-IN') : 'N/A' %>
                      <span>/ night</span>
                      <i class="tax-info text-muted"> &nbsp;+18% GST</i>
                    </p>
                  </div>
                </div>
              </div>
            <% } %>
        </div>
        <% } else { %>
          <div class="text-center py-5">
            <img src="https://cdn-icons-png.flaticon.com/512/6134/6134065.png" alt="No exact match" width="120"
              class="mb-3 opacity-50">
            <h3 class="text-dark">No exact matches found</h3>
            <p class="text-muted">Try changing or removing some of your filters or adjusting your search.</p>
            <a href="/listings" class="btn btn-outline-dark rounded-pill mt-3 px-4">Remove all filters</a>
          </div>
          <% } %>

            <script>
              // Highlighting active category
              document.addEventListener("DOMContentLoaded", () => {
                if (window.currentCategory) {
                  const filters = document.querySelectorAll('.filter');
                  filters.forEach(f => {
                    if (f.href.includes(`category=${window.currentCategory}`)) {
                      f.classList.add('active');
                      f.style.opacity = '1';
                      f.style.borderBottom = '2px solid #222';
                      f.style.paddingBottom = '8px';
                    }
                  });
                }

                // Tax toggle functionality
                let taxToggle = document.getElementById("switchCheckDefault");
                if (taxToggle) {
                  taxToggle.addEventListener("change", () => {
                    let taxinfos = document.querySelectorAll(".tax-info");
                    taxinfos.forEach(info => {
                      if (taxToggle.checked) {
                        info.style.display = "inline";
                      } else {
                        info.style.display = "none";
                      }
                    });
                  });
                }
              });
            </script>