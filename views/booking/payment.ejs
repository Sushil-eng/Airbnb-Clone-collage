<% layout("/layouts/boilerplate") %>

<div class="container mt-5 mb-5 d-flex justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
      <!-- Header Area showing what is being purchased -->
      <div class="bg-dark text-white p-4">
        <h4 class="fw-bold mb-1">Confirm and pay</h4>
        <p class="mb-0 text-white-50"><%= nights %> nights in <%= listing.location %></p>
      </div>

      <div class="card-body p-4 p-md-5">
        
        <!-- Summary Box -->
        <div class="d-flex align-items-center mb-4 p-3 border rounded-4 bg-light">
          <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="rounded-3 me-3 object-fit-cover" style="width: 80px; height: 80px;">
          <div>
            <h6 class="fw-bold mb-1"><%= listing.title %></h6>
            <p class="text-muted mb-0 small">Total: <strong>&#8377; <%= totalPrice.toLocaleString('en-IN') %></strong></p>
          </div>
        </div>

        <hr class="mb-4">

        <h5 class="fw-bold mb-4">Payment details</h5>

        <!-- Static Fake Form that Submits to a Finalize Booking Route -->
        <form action="/booking/<%= listing._id %>/finalize" method="POST" class="needs-validation" novalidate>
          
          <!-- Hidden Inputs to carry the selected dates over -->
          <input type="hidden" name="checkIn" value="<%= checkIn %>">
          <input type="hidden" name="checkOut" value="<%= checkOut %>">
          <input type="hidden" name="totalPrice" value="<%= totalPrice %>">

          <div class="mb-3">
            <label class="form-label fw-semibold text-muted small text-uppercase">Card Number</label>
            <div class="input-group">
              <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="fa-regular fa-credit-card"></i></span>
              <input type="text" class="form-control border-start-0 py-2 shadow-none" placeholder="0000 0000 0000 0000" required maxlength="19">
            </div>
          </div>

          <div class="row mb-4">
            <div class="col-6">
              <label class="form-label fw-semibold text-muted small text-uppercase">Expiration</label>
              <input type="text" class="form-control py-2 shadow-none" placeholder="MM/YY" required maxlength="5">
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold text-muted small text-uppercase">CVV</label>
              <input type="password" class="form-control py-2 shadow-none" placeholder="123" required maxlength="4">
            </div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold text-muted small text-uppercase">Name on card</label>
            <input type="text" class="form-control py-2 shadow-none" placeholder="John Doe" required>
          </div>

          <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 fw-bold fs-5 mt-2 shadow">
            Pay &#8377; <%= totalPrice.toLocaleString('en-IN') %>
          </button>
          
          <div class="mt-3 text-center text-muted small">
            <i class="fa-solid fa-lock me-1"></i> Payments are secure and encrypted
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
